# ── dotrino-telegram-claude-bot ──────────────────────────────────────────────
# Copia este archivo a `.env` y completa al menos TELEGRAM_BOT_TOKEN.
# (También podés pasar cualquier variable por el entorno, sin archivo.)
# Las que se "autogeneran" se crean solas en el primer arranque y quedan guardadas.

# ── REQUERIDO ────────────────────────────────────────────────────────────────
# Token del bot, que te da @BotFather al crear el bot.
TELEGRAM_BOT_TOKEN=123456789:AA-pega-aqui-tu-token

# ── Claude ───────────────────────────────────────────────────────────────────
# Carpeta donde corre Claude (con memoria). Default: el directorio actual (cwd).
CLAUDE_CWD=/ruta/a/tu/proyecto

# Flags extra que se le pasan a `claude -p`. VACÍO = modo seguro (Claude responde
# y lee, pero NO ejecuta comandos ni edita sin permiso).
#   • Autonomía total (ejecuta/edita SIN pedir permiso — riesgoso, sobre túnel público):
#       CLAUDE_FLAGS=--dangerously-skip-permissions
#   • Elegir modelo / nivel de razonamiento:
#       CLAUDE_FLAGS=--model claude-sonnet-4-6 --effort medium
#   • Combinado:
#       CLAUDE_FLAGS=--dangerously-skip-permissions --model claude-opus-4-8
CLAUDE_FLAGS=

# ── Autorización ─────────────────────────────────────────────────────────────
# Id de Telegram del ÚNICO usuario autorizado. Si lo dejás VACÍO, el bot NO atiende a
# nadie: a cada mensaje responde con el id de quien escribe y cómo autorizarlo (no captura
# a nadie automáticamente → nadie "gana" la autorización por escribir primero). Poné aquí
# tu id (te lo dice el propio bot, o el comando /id) y reinicia.
ALLOWED_USER_ID=

# ── Opcionales (tienen default, normalmente no hace falta tocarlos) ──────────
# CLAUDE_BIN=claude                      # binario de claude (o ruta completa)
# CLAUDE_TIMEOUT=0                        # segundos máx por respuesta; 0 = SIN límite (default)
# COMPACT_AT_TOKENS=150000                # auto /compact cuando el contexto supera N tokens; 0 = off
# COMPACT_AFTER_IDLE_HOURS=6              # auto /compact al retomar tras N horas sin mensajes; 0 = off
# TUNNEL_SERVER=https://r.dotrino.com     # relay del túnel reverso (@dotrino/tunnel)
# TUNNEL_KEY=                             # se autogenera y persiste → URL pública estable
# TG_WEBHOOK_SECRET=                      # se autogenera → valida que el request sea de Telegram
# CLAUDE_SESSION_ID=                      # memoria de la conversación (se guarda sola)
